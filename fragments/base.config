# ==============================================================================
# base.config – cross-cutting options for all yacks builds
# ==============================================================================
# Compiler, LTO, module compression, zswap, initramfs, scheduling, preemption,
# timer, memory, containers, security, debug, boot, module signing.
# ==============================================================================

# --- Compiler & LTO ----------------------------------------------------------
CONFIG_LTO_NONE=y
# CONFIG_LTO_CLANG is not set
# CONFIG_LTO_CLANG_FULL is not set
# CONFIG_LTO_CLANG_THIN is not set
# CONFIG_GCC_PLUGINS is not set
# CONFIG_LTO_GCC is not set
# CONFIG_LTO is not set
CONFIG_CC_OPTIMIZE_FOR_PERFORMANCE=y
# CONFIG_CC_OPTIMIZE_FOR_SIZE is not set

# CFI (Clang-only, not applicable to GCC builds)
# CONFIG_CFI_CLANG is not set
# CONFIG_CFI_PERMISSIVE is not set

# --- Module compression (zstd) -----------------------------------------------
CONFIG_MODULE_COMPRESS=y
CONFIG_MODULE_COMPRESS_ALL=y
CONFIG_MODULE_COMPRESS_ZSTD=y
# CONFIG_MODULE_DECOMPRESS is not set
# CONFIG_MODULE_COMPRESS_GZIP is not set
# CONFIG_MODULE_COMPRESS_XZ is not set
# CONFIG_MODULE_COMPRESS_NONE is not set

# --- Firmware loader with zstd support ---------------------------------------
CONFIG_FW_LOADER=y
CONFIG_FW_LOADER_COMPRESS=y
CONFIG_FW_LOADER_COMPRESS_ZSTD=y
CONFIG_FW_LOADER_USER_HELPER=y

# --- Swap compression (zswap) ------------------------------------------------
CONFIG_ZSWAP=y
CONFIG_ZSWAP_DEFAULT_ON=y
CONFIG_ZSWAP_SHRINKER_DEFAULT_ON=y
CONFIG_CRYPTO_ZSTD=y
CONFIG_ZSWAP_COMPRESSOR_DEFAULT_ZSTD=y
CONFIG_ZSWAP_COMPRESSOR_DEFAULT="zstd"
# CONFIG_ZSWAP_COMPRESSOR_DEFAULT_LZO is not set

# --- Initramfs (required by Mint) --------------------------------------------
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y
CONFIG_RD_ZSTD=y

# --- Timer & scheduling ------------------------------------------------------
CONFIG_TICK_CPU_ACCOUNTING=y
# CONFIG_VIRT_CPU_ACCOUNTING_GEN is not set
# CONFIG_NTP_PPS is not set
# CONFIG_SCHED_CLASS_EXT is not set
# CONFIG_SCHED_CORE is not set
CONFIG_SCHED_AUTOGROUP=y
CONFIG_PER_VMA_LOCK=y
CONFIG_LRU_GEN=y
CONFIG_LRU_GEN_ENABLED=y

# --- Preemption (dynamic = best of both worlds on desktop) ------------------
CONFIG_PREEMPT=y
CONFIG_PREEMPT_DYNAMIC=y
# CONFIG_PREEMPT_VOLUNTARY is not set
# CONFIG_PREEMPT_NONE is not set

# --- Timer frequency: 1000 Hz for smooth desktop ----------------------------
# CONFIG_HZ_PERIODIC is not set
# CONFIG_NO_HZ_FULL is not set
CONFIG_NO_HZ_COMMON=y
CONFIG_NO_HZ_IDLE=y
# CONFIG_HZ_250 is not set
# CONFIG_HZ_500 is not set
CONFIG_HZ_1000=y
CONFIG_HZ=1000

# --- Memory ------------------------------------------------------------------
CONFIG_TRANSPARENT_HUGEPAGE=y
# CONFIG_TRANSPARENT_HUGEPAGE_ALWAYS is not set
CONFIG_TRANSPARENT_HUGEPAGE_MADVISE=y
CONFIG_COMPACTION=y
CONFIG_MIGRATION=y
# CONFIG_KSM is not set
CONFIG_NUMA_BALANCING=y
CONFIG_NUMA_BALANCING_DEFAULT_ENABLED=y

# --- Containers / Flatpak / Snap (Mint) --------------------------------------
CONFIG_USER_NS=y
CONFIG_CGROUPS=y
CONFIG_NAMESPACES=y

# --- Security: AppArmor (Mint default) – no SELinux -------------------------
CONFIG_SECURITY_APPARMOR=y
CONFIG_DEFAULT_SECURITY_APPARMOR=y
# CONFIG_SECURITY_SELINUX is not set

# --- Unused subsystems -------------------------------------------------------
# CONFIG_HAMRADIO is not set
# CONFIG_CAN is not set
# CONFIG_NFC is not set
# CONFIG_WIMAX is not set
# CONFIG_PCMCIA is not set
# CONFIG_FIREWIRE is not set
# CONFIG_INFINIBAND is not set
# CONFIG_PHONE is not set
# CONFIG_ARCNET is not set
# CONFIG_ISDN is not set
# CONFIG_PARPORT is not set
# CONFIG_BLK_DEV_FD is not set
# CONFIG_ATM is not set
# CONFIG_STAGING is not set
# CONFIG_IIO is not set
# CONFIG_MTD is not set
# CONFIG_MTD_NAND_ECC_MXIC is not set
# CONFIG_NTB is not set
# CONFIG_FPGA is not set
# CONFIG_I3C is not set
# CONFIG_GNSS is not set
# CONFIG_CXL_BUS is not set
# CONFIG_IOATDMA is not set
# CONFIG_DCA is not set
# CONFIG_GREYBUS is not set
# CONFIG_COMEDI is not set
# CONFIG_HSI is not set
# CONFIG_A11Y_BRAILLE_CONSOLE is not set
# CONFIG_SPEAKUP is not set

# --- Virtualization guests: bare-metal desktop, no hypervisor ----------------
# CONFIG_XEN is not set
# CONFIG_XEN_PV is not set
# CONFIG_XEN_PVHVM is not set
# CONFIG_XEN_512GB is not set
# CONFIG_XEN_SAVE_RESTORE is not set
# CONFIG_XEN_BALLOON is not set
# CONFIG_XEN_DEV_EVTCHN is not set
# CONFIG_XEN_BACKEND is not set
# CONFIG_XEN_BLKDEV_FRONTEND is not set
# CONFIG_XEN_NETDEV_FRONTEND is not set
# CONFIG_XEN_PCIDEV_FRONTEND is not set
# CONFIG_HYPERV is not set
# CONFIG_HYPERV_UTILS is not set
# CONFIG_HYPERV_BALLOON is not set

# --- Network protocols -------------------------------------------------------
CONFIG_WIREGUARD=y
# CONFIG_IPX is not set
# CONFIG_ATALK is not set
# CONFIG_X25 is not set
# CONFIG_DECNET is not set
# CONFIG_TIPC is not set
# CONFIG_DCCP is not set
# CONFIG_RDS is not set
# CONFIG_L2TP is not set

# --- Faster boot -------------------------------------------------------------
# CONFIG_PRINTK_TIME is not set
# CONFIG_BOOT_PRINTK_DELAY is not set

# --- Debug / tracing: all off for production ---------------------------------
CONFIG_DEBUG_INFO_NONE=y
# CONFIG_MODVERSIONS is not set
# CONFIG_ASM_MODVERSIONS is not set
# CONFIG_EXTENDED_MODVERSIONS is not set
# CONFIG_BASIC_MODVERSIONS is not set
# CONFIG_GENKSYMS is not set
# CONFIG_FTRACE is not set
# CONFIG_KPROBES is not set
# CONFIG_LIVEPATCH is not set
# CONFIG_DEBUG_INFO_BTF is not set
# CONFIG_DEBUG_INFO is not set
# CONFIG_DEBUG_INFO_DWARF4 is not set
# CONFIG_DEBUG_INFO_DWARF5 is not set
# CONFIG_DEBUG_INFO_DWARF_TOOLCHAIN_DEFAULT is not set
# CONFIG_DEBUG_KMAP_LOCAL_FORCE_MAP is not set
# CONFIG_DEBUG_CGROUP_REF is not set
# CONFIG_DEBUG_OBJECTS is not set
# CONFIG_KCOV is not set
# CONFIG_PROVE_LOCKING is not set
# CONFIG_LOCK_STAT is not set
# CONFIG_KGDB is not set
# CONFIG_UBSAN is not set
# CONFIG_KASAN is not set
# CONFIG_PAGE_OWNER is not set
# CONFIG_DRM_DEBUG_DP_MST_TOPOLOGY_REFS is not set
# CONFIG_DRM_DEBUG_MODESET_LOCK is not set
# CONFIG_DRM_PANIC_DEBUG is not set
# CONFIG_KPROBE_EVENTS is not set
# CONFIG_SAMPLE_KPROBES is not set
# CONFIG_FUNCTION_ERROR_INJECTION is not set

# --- Module signing: clear keys (custom build, not distro-signed) -----------
CONFIG_SYSTEM_REVOCATION_KEYS=""
CONFIG_SYSTEM_TRUSTED_KEYS=""
# CONFIG_MODULE_SIG_ALL is not set
