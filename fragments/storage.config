# ==============================================================================
# storage.config – NVMe, SATA, SCSI, filesystems, I/O scheduler
# ==============================================================================
# Hardware:
#   SSD:  Samsung 970 EVO Plus 1 TB (NVMe PCIe 3.0 x4) btrfs/ext4
#   HDD:  Western Digital 1 TB (SATA) ntfs
#   SSD2: Lexar NM620 1 TB (SATA) ntfs
#   SSD3: Samsung 850 EVO 500 GB (SATA) ntfs
#   DVD:  TSSTcorp SH-S203D (SATA)
#   SDCard Readers: USB-connected (covered by USB/MMC in hardware-desktop.config)
# ==============================================================================

# --- NVMe --------------------------------------------------------------------
CONFIG_NVME_CORE=y
CONFIG_BLK_DEV_NVME=y
CONFIG_NVME_MULTIPATH=y
CONFIG_NVME_HWMON=y

# --- SATA + ATA --------------------------------------------------------------
CONFIG_SATA_AHCI=y
CONFIG_ATA=y

# --- SCSI layer (for SATA + optical) -----------------------------------------
CONFIG_SCSI=y
CONFIG_BLK_DEV_SD=y
CONFIG_BLK_DEV_SR=y

# --- I/O scheduler: BFQ for desktop mixed workloads -------------------------
# Note: CONFIG_DEFAULT_IOSCHED was removed in 6.18; BFQ is assigned to
# rotational devices at runtime via udev.
CONFIG_MQ_IOSCHED_DEADLINE=y
CONFIG_IOSCHED_BFQ=y
CONFIG_BFQ_GROUP_IOSCHED=y

# --- Filesystems: needed on this system --------------------------------------
CONFIG_EXT4_FS=y
CONFIG_BTRFS_FS=y
CONFIG_CIFS=m
CONFIG_VFAT_FS=y
CONFIG_NTFS3_FS=y
CONFIG_FUSE_FS=y
CONFIG_OVERLAY_FS=y
CONFIG_TMPFS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_EXFAT_FS=m
CONFIG_ISO9660_FS=y
CONFIG_UDF_FS=y
CONFIG_F2FS_FS=m

# --- Filesystems: exotic / not needed ----------------------------------------
# CONFIG_REISERFS_FS is not set
# CONFIG_JFS_FS is not set
# CONFIG_NILFS2_FS is not set
# CONFIG_EROFS_FS is not set
# CONFIG_XFS_FS is not set
# CONFIG_OCFS2_FS is not set
# CONFIG_GFS2_FS is not set
# CONFIG_CEPH_FS is not set
# CONFIG_ORANGEFS_FS is not set
# CONFIG_AFS_FS is not set
# CONFIG_9P_FS is not set
# CONFIG_CODA_FS is not set
# CONFIG_HFS_FS is not set
# CONFIG_HFSPLUS_FS is not set
# CONFIG_MINIX_FS is not set
# CONFIG_ROMFS_FS is not set
# CONFIG_CRAMFS is not set
# CONFIG_UFS_FS is not set

# --- SCSI HBA: keep core (sd/sr/sg), disable FC/SAS enterprise adapters -----
# CONFIG_SCSI_QLA_FC is not set
# CONFIG_SCSI_QLA_ISCSI is not set
# CONFIG_SCSI_LPFC is not set
# CONFIG_SCSI_BFA_FC is not set
# CONFIG_SCSI_FNIC is not set
# CONFIG_SCSI_SNIC is not set
# CONFIG_SCSI_AIC7XXX is not set
# CONFIG_SCSI_AIC79XX is not set
# CONFIG_SCSI_AIC94XX is not set
# CONFIG_SCSI_MVSAS is not set
# CONFIG_SCSI_MVUMI is not set
# CONFIG_MEGARAID_SAS is not set
# CONFIG_MEGARAID_LEGACY is not set
# CONFIG_MEGARAID_NEWGEN is not set
# CONFIG_MEGARAID_MM is not set
# CONFIG_MEGARAID_MAILBOX is not set
# CONFIG_SCSI_MPT3SAS is not set
# CONFIG_SCSI_MPT2SAS is not set
# CONFIG_SCSI_AACRAID is not set
# CONFIG_SCSI_HPSA is not set
# CONFIG_SCSI_SMARTPQI is not set
# CONFIG_SCSI_PM8001 is not set
# CONFIG_SCSI_ISCI is not set
# CONFIG_SCSI_ESAS2R is not set
# CONFIG_SCSI_BNX2_ISCSI is not set
# CONFIG_SCSI_BNX2X_FCOE is not set
# CONFIG_SCSI_CXGB3_ISCSI is not set
# CONFIG_SCSI_CXGB4_ISCSI is not set
# CONFIG_SCSI_CSIOSTOR is not set
# CONFIG_SCSI_VIRTIO is not set
