# ==============================================================================
# cpu-amd-zen4.config – AMD Zen 4 / Ryzen 9 7950X3D specifics
# ==============================================================================
# Hardware:
#   CPU:      AMD Ryzen 9 7950X3D (Zen 4, 16c/32t)
#   Mainboard: MSI MPG X670E Carbon WiFi
#   RAM:      Kingston FURY Beast 64 GB DDR5-6000 CL30-36-36 (KF560C30BBEK2-64, KF560C30-32 x2)
# ==============================================================================

# --- CPU: AMD Zen 4 / Ryzen 9 7950X3D ---------------------------------------
CONFIG_SCHED_MC_PRIO=y
CONFIG_SCHED_MC=y
CONFIG_SCHED_SMT=y
CONFIG_CPU_SUP_AMD=y
# CONFIG_CPU_SUP_INTEL is not set
# CONFIG_CPU_SUP_CENTAUR is not set
# CONFIG_CPU_SUP_ZHAOXIN is not set
CONFIG_NR_CPUS=32
# CONFIG_GENERIC_CPU is not set
# CONFIG_X86_64_V3 is not set
# CONFIG_X86_64_V4 is not set
# CONFIG_X86_32 is not set
# CONFIG_MAXSMP is not set
CONFIG_X86_MCE_AMD=y
# CONFIG_X86_ANCIENT_MCE is not set
CONFIG_X86_X2APIC=y
CONFIG_ACPI_PROCESSOR_IDLE=y
CONFIG_CPU_IDLE_GOV_LADDER=y
CONFIG_CPU_IDLE_GOV_MENU=y

# --- AMD platform / SMBus / GPIO ---------------------------------------------
CONFIG_AMD_NB=y
CONFIG_EDAC_DECODE_MCE=y
CONFIG_EDAC_AMD64=y
CONFIG_AMD_IOMMU=y
CONFIG_X86_AMD_PLATFORM_DEVICE=y
CONFIG_PINCTRL_AMD=y
CONFIG_I2C_PIIX4=m
CONFIG_GPIO_AMD_FCH=m

# --- AMD memory encryption (SME / SEV) ---------------------------------------
CONFIG_AMD_MEM_ENCRYPT=y
# CONFIG_AMD_MEM_ENCRYPT_ACTIVE_BY_DEFAULT is not set

# --- CPU frequency scaling: AMD P-State + SCHEDUTIL -------------------------
CONFIG_CPU_FREQ=y
CONFIG_X86_AMD_PSTATE=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y
CONFIG_ENERGY_MODEL=y
# CONFIG_CPU_FREQ_DEFAULT_GOV_PERFORMANCE is not set
# CONFIG_CPU_FREQ_DEFAULT_GOV_POWERSAVE is not set
# CONFIG_CPU_FREQ_DEFAULT_GOV_USERSPACE is not set
# CONFIG_CPU_FREQ_DEFAULT_GOV_ONDEMAND is not set
# CONFIG_CPU_FREQ_DEFAULT_GOV_CONSERVATIVE is not set
# CONFIG_CPU_FREQ_GOV_ONDEMAND is not set
# CONFIG_CPU_FREQ_GOV_CONSERVATIVE is not set
# CONFIG_CPU_FREQ_GOV_POWERSAVE is not set
# CONFIG_X86_ACPI_CPUFREQ is not set

# --- Hardware monitoring (MSI X670E) -----------------------------------------
CONFIG_HWMON=y
CONFIG_SENSORS_NCT6683=m
CONFIG_SENSORS_K10TEMP=m
CONFIG_SENSORS_FAM15H_POWER=m

# --- Crypto: AES-NI + AVX2 (Zen 4 native) ------------------------------------
CONFIG_CRYPTO_AES_NI_INTEL=y
CONFIG_CRYPTO_AES=y
CONFIG_CRYPTO_XTS=y
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_USER_API_SKCIPHER=m

# --- ACPI --------------------------------------------------------------------
CONFIG_ACPI=y
CONFIG_ACPI_BUTTON=y

# --- PCIe (X670E: PCIe 5.0 host) ---------------------------------------------
CONFIG_PCIEAER=y
CONFIG_PCIEPORTBUS=y
