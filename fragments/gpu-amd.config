# ==============================================================================
# gpu-amd.config – AMD Radeon RX 9070 (RDNA 4)
# ==============================================================================
# Self-contained: works with or without gpu-nvidia.config.
# When both are active, this fragment is loaded last and wins on conflicts
# (only real conflict: DRM_AMDGPU — nvidia disables it, this file enables it).
# To switch from NVIDIA: comment out gpu-nvidia.config in buildKernel.sh.
# ==============================================================================

# --- DRM core (needed for EFI boot framebuffer) ------------------------------
CONFIG_DRM=y
CONFIG_DRM_SIMPLEDRM=y
CONFIG_DRM_FBDEV_EMULATION=y

# --- Framebuffer -------------------------------------------------------------
CONFIG_FB=y
CONFIG_FB_EFI=y
CONFIG_FB_VESA=y

# --- AMD GPU driver ----------------------------------------------------------
CONFIG_DRM_AMDGPU=m
# CONFIG_DRM_AMDGPU_CIK is not set
# CONFIG_DRM_AMDGPU_SI is not set
# CONFIG_DRM_RADEON is not set

# --- ROCm / HIP compute (HSA_AMD auto-enables DRM_AMDGPU_USERPTR) ------------
CONFIG_HSA_AMD=y
CONFIG_HSA_AMD_SVM=y

# --- Disable NVIDIA drivers --------------------------------------------------
# CONFIG_DRM_NOUVEAU is not set
# CONFIG_NOUVEAU_PLATFORM_DRIVER is not set
# CONFIG_DRM_NOUVEAU_BACKLIGHT is not set
# CONFIG_DRM_NOVA is not set

# --- Disable Intel GPU drivers -----------------------------------------------
# CONFIG_DRM_I915 is not set
# CONFIG_DRM_XE is not set
# CONFIG_DRM_ACCEL_IVPU is not set

# --- Disable virtual / hypervisor / server display controllers ---------------
# CONFIG_DRM_VMWGFX is not set
# CONFIG_DRM_QXL is not set
# CONFIG_DRM_VIRTIO_GPU is not set
# CONFIG_DRM_BOCHS is not set
# CONFIG_DRM_CIRRUS_QEMU is not set
# CONFIG_DRM_VBOXVIDEO is not set
# CONFIG_DRM_HYPERV is not set
# CONFIG_DRM_XEN is not set
# CONFIG_DRM_XEN_FRONTEND is not set
# CONFIG_DRM_AST is not set
# CONFIG_DRM_MGAG200 is not set
# CONFIG_DRM_GMA500 is not set
# CONFIG_DRM_VGEM is not set
# CONFIG_DRM_VKMS is not set
# CONFIG_DRM_UDL is not set

# --- Disable AI/ML accelerators (use ROCm userspace instead) -----------------
# CONFIG_DRM_ACCEL_HABANALABS is not set
# CONFIG_DRM_ACCEL_QAIC is not set
# CONFIG_DRM_ACCEL_AMDXDNA is not set
# CONFIG_DRM_ACCEL_ROCKET is not set
