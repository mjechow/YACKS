# ==============================================================================
# hardware-desktop.config – desktop peripheral drivers and platform settings
# ==============================================================================
# Hardware:
#   Keyboard:  Logitech MX Keys (USB receiver)
#   Mouse:     Asus ROG Keris Wireless Aimpoint (USB receiver)
#   Webcam:    Logitech C920 (USB, UVC)
#   HeadSet:   BeyerDynamic MMX 200 (USB wireless adapter / Bluetooth)
#   Printer:   HP Color Laser Jet Pro MFP M477fdn (USB)
#   SDCard:    Lexar LRW400U + Graugear G-MP01CR (USB-connected)
#   DVD:       TSSTcorp SH-S203D (covered in storage.config)
#   USB Dock:  Anker 675
#   Phone:     Samsung S20FE (MTP via userspace/gvfs, no kernel config needed)
# ==============================================================================

# --- USB ---------------------------------------------------------------------
CONFIG_USB_SUPPORT=y
CONFIG_USB_STORAGE=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_PRINTER=m
CONFIG_USB_EHCI_HCD=m

# --- Input -------------------------------------------------------------------
CONFIG_INPUT_EVDEV=y
CONFIG_HID_GENERIC=m
CONFIG_USB_HID=m

# SD card readers (USB-connected)
CONFIG_MMC_BLOCK=m
CONFIG_MMC_SDHCI_PCI=m

# No game controllers on this system
# CONFIG_INPUT_JOYDEV is not set
# CONFIG_JOYSTICK_XPAD is not set
# CONFIG_HID_PLAYSTATION is not set
# CONFIG_HID_STEAM is not set

# --- Input: disable touchscreen (desktop system) -----------------------------
# CONFIG_INPUT_TOUCHSCREEN is not set

# --- Media: UVC webcam only – disable TV/DVB/radio/IR/gspca -----------------
# CONFIG_MEDIA_ANALOG_TV_SUPPORT is not set
# CONFIG_MEDIA_DIGITAL_TV_SUPPORT is not set
# CONFIG_MEDIA_RADIO_SUPPORT is not set
# CONFIG_MEDIA_SDR_SUPPORT is not set
# CONFIG_MEDIA_PLATFORM_SUPPORT is not set
# CONFIG_MEDIA_TEST_SUPPORT is not set
# CONFIG_MEDIA_PCI_SUPPORT is not set
# CONFIG_VIDEO_IR_I2C is not set
# CONFIG_RC_CORE is not set
# CONFIG_RC_MAP is not set
# CONFIG_LIRC is not set
# CONFIG_USB_GSPCA is not set
# CONFIG_DVB_CORE is not set

# Logitech C920 UVC webcam
CONFIG_MEDIA_USB_SUPPORT=y
CONFIG_USB_VIDEO_CLASS=m

# --- Watchdog: disable (desktop, not server) ---------------------------------
# CONFIG_WATCHDOG is not set

# --- Crypto HW: disable non-AMD accelerators ---------------------------------
# Rules: hidden tristates (QAT, NITROX) are selected by children — every child
# is explicitly disabled so nothing re-selects the parent.
# CONFIG_CRYPTO_DEV_QAT is not set
# CONFIG_CRYPTO_DEV_QAT_DH895xCC is not set
# CONFIG_CRYPTO_DEV_QAT_C3XXX is not set
# CONFIG_CRYPTO_DEV_QAT_C62X is not set
# CONFIG_CRYPTO_DEV_QAT_4XXX is not set
# CONFIG_CRYPTO_DEV_QAT_420XX is not set
# CONFIG_CRYPTO_DEV_QAT_6XXX is not set
# CONFIG_CRYPTO_DEV_QAT_DH895xCCVF is not set
# CONFIG_CRYPTO_DEV_QAT_C3XXXVF is not set
# CONFIG_CRYPTO_DEV_QAT_C62XVF is not set
# CONFIG_CRYPTO_DEV_QAT_ERROR_INJECTION is not set
# CONFIG_QAT_VFIO_PCI is not set
# CONFIG_CRYPTO_DEV_CAVIUM_ZIP is not set
# CONFIG_CRYPTO_DEV_NITROX is not set
# CONFIG_CRYPTO_DEV_NITROX_CNN55XX is not set
# CONFIG_CRYPTO_DEV_CHELSIO is not set
# CONFIG_CRYPTO_DEV_VIRTIO is not set
# CONFIG_CRYPTO_DEV_AMLOGIC_GXL is not set
# CONFIG_CRYPTO_DEV_INSIDE_SECURE is not set
# CONFIG_CRYPTO_DEV_PADLOCK is not set
# CONFIG_CRYPTO_DEV_PADLOCK_AES is not set
# CONFIG_CRYPTO_DEV_PADLOCK_SHA is not set
# CONFIG_CRYPTO_DEV_ATMEL_I2C is not set
# CONFIG_CRYPTO_DEV_ATMEL_ECC is not set
# CONFIG_CRYPTO_DEV_ATMEL_SHA204A is not set

# --- Platform: disable laptop/embedded/server platform drivers ---------------
# CONFIG_CHROME_PLATFORMS is not set
# CONFIG_SURFACE_PLATFORMS is not set
# CONFIG_MELLANOX_PLATFORM is not set

# --- VFIO (GPU passthrough / VM isolation) -----------------------------------
CONFIG_VFIO=m
CONFIG_VFIO_PCI=m
