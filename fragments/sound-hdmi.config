# ==============================================================================
# sound-hdmi.config – HDMI/DisplayPort audio codecs
# ==============================================================================
# Hardware:
#   GPU: AMD RX 9070 (ATI codec) + NVIDIA RTX 3070 (NVIDIA codec)
#   Comment out this file to disable all display audio.
# ==============================================================================

CONFIG_SND_HDA_CODEC_HDMI=m
# CONFIG_SND_HDA_CODEC_HDMI_SIMPLE is not set
# CONFIG_SND_HDA_CODEC_HDMI_INTEL is not set
CONFIG_SND_HDA_CODEC_HDMI_ATI=m
CONFIG_SND_HDA_CODEC_HDMI_NVIDIA=m
# CONFIG_SND_HDA_CODEC_HDMI_NVIDIA_MCP is not set
# CONFIG_SND_HDA_CODEC_HDMI_TEGRA is not set
# CONFIG_SND_HDA_INTEL_HDMI_SILENT_STREAM is not set
