# ==============================================================================
# sound-realtek.config – Realtek ALC4080 via HDA Intel controller + USB audio
# ==============================================================================
# Hardware:
#   Sound: Onboard Realtek ALC4080 (3.5mm)
#   HeadSet: BeyerDynamic MMX 200 (USB wireless adapter / Bluetooth)
# ==============================================================================

# --- HDA Intel + Realtek codec -----------------------------------------------
CONFIG_SND_HDA_INTEL=m
CONFIG_SND_HDA_CODEC_REALTEK=m
CONFIG_SND_HDA_GENERIC=m

# PipeWire / PulseAudio basics
CONFIG_SND_TIMER=m
CONFIG_SND_PCM=m

# --- Disable all unused HDA codecs -------------------------------------------
# CONFIG_SND_HDA_CODEC_ANALOG is not set
# CONFIG_SND_HDA_CODEC_SIGMATEL is not set
# CONFIG_SND_HDA_CODEC_VIA is not set
# CONFIG_SND_HDA_CODEC_CONEXANT is not set
# CONFIG_SND_HDA_CODEC_SENARYTECH is not set
# CONFIG_SND_HDA_CODEC_CA0110 is not set
# CONFIG_SND_HDA_CODEC_CA0132 is not set
# CONFIG_SND_HDA_CODEC_CMEDIA is not set
# CONFIG_SND_HDA_CODEC_CM9825 is not set
# CONFIG_SND_HDA_CODEC_SI3054 is not set
# CONFIG_SND_HDA_CODEC_CIRRUS is not set
# CONFIG_SND_HDA_CODEC_CS420X is not set
# CONFIG_SND_HDA_CODEC_CS421X is not set
# CONFIG_SND_HDA_CODEC_CS8409 is not set

# --- USB audio (BeyerDynamic MMX 200 wireless adapter) -----------------------
CONFIG_SND_USB_AUDIO=m
# CONFIG_SND_USB_UA101 is not set
# CONFIG_SND_USB_USX2Y is not set
# CONFIG_SND_USB_CAIAQ is not set
# CONFIG_SND_USB_US122L is not set
# CONFIG_SND_USB_US144MKII is not set
# CONFIG_SND_USB_6FIRE is not set
# CONFIG_SND_USB_HIFACE is not set

# --- Disable entire Intel SOC audio stack (not needed on AMD) ----------------
# CONFIG_SND_SOC_INTEL_SST_TOPLEVEL is not set
# CONFIG_SND_SOC_INTEL_EHL_RT5660_MACH is not set
# CONFIG_SND_SOC_INTEL_SKL_HDA_DSP_GENERIC_MACH is not set
# CONFIG_SND_SOC_INTEL_SOF_DA7219_MACH is not set
# CONFIG_SND_SOC_INTEL_SOF_CS42L42_MACH is not set
# CONFIG_SND_SOC_INTEL_SOF_ES8336_MACH is not set
# CONFIG_SND_SOC_INTEL_SOF_NAU8825_MACH is not set
# CONFIG_SND_SOC_INTEL_SOF_PCM512x_MACH is not set

# --- Disable AMD APU audio (7950X3D is CPU-only, no integrated audio) --------
# CONFIG_SND_SOC_AMD_ACP3x is not set
# CONFIG_SND_SOC_AMD_ACP5x is not set
# CONFIG_SND_SOC_AMD_ACP6x is not set
# CONFIG_SND_SOC_AMD_RAVEN is not set
# CONFIG_SND_SOC_AMD_RENOIR is not set
# CONFIG_SND_SOC_AMD_VANGOGH is not set
# CONFIG_SND_SOC_AMD_YC is not set
# CONFIG_SND_SOC_AMD_PS is not set
# CONFIG_SND_SOC_AMD_RPL is not set
